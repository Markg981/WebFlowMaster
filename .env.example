# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (production) OR a local PGlite data directory path.
# Examples:
#   DATABASE_URL=postgres://user:password@localhost:5432/webflowmaster
#   DATABASE_URL=./data/local-pg
DATABASE_URL=./data/local-pg

# Optional: source Neon/Postgres URL used only by scripts/migrate-data.ts
NEON_DATABASE_URL=

# ─── Redis (sessions, BullMQ queue/worker) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies. Generate a fresh one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# 32-byte (64 hex chars) key used to encrypt stored secrets (AES-256-GCM).
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-64-hex-characters

# ─── AI Self-Healing (optional) ──────────────────────────────────────────────
# Google Gemini API key; when unset, AI self-healing features are disabled.
GEMINI_API_KEY=

# ─── Logging / Observability ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_RETENTION_DAYS=7
# Optional Loki endpoint for centralized logs
LOKI_URL=http://localhost:3100
